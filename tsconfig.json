{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "preserve",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["bun"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "weysabi": ["packages/weysabi/src/index.ts"],
      "weysabi/errors": ["packages/weysabi/src/errors.ts"],
      "weysabi/sse": ["packages/weysabi/src/sse.ts"],
      "weysabi/hono": ["packages/weysabi/src/hono.ts"],
      "weysabi/next": ["packages/weysabi/src/next.ts"],
      "weysabi/express": ["packages/weysabi/src/express.ts"],
      "weysabi/fastify": ["packages/weysabi/src/fastify.ts"],
      "weysabi/elysia": ["packages/weysabi/src/elysia.ts"],
      "weysabi/ai-sdk": ["packages/weysabi/src/ai-sdk.ts"],
      "weysabi/otel": ["packages/weysabi/src/otel.ts"],
      "weysabi/cache": ["packages/weysabi/src/cache.ts"],
      "weysabi/client": ["packages/weysabi/src/client.ts"],
      "weysabi/rag": ["packages/weysabi/src/rag/index.ts"],
      "weysabi/chat": ["packages/weysabi/src/chat/index.ts"],
      "weysabi/guardrails": ["packages/weysabi/src/guardrails/index.ts"],
      "weysabi/prompts": ["packages/weysabi/src/prompts/index.ts"],
      "weysabi/cli": ["packages/weysabi/src/cli/public.ts"],
      "weysabi-server": ["packages/server/src/index.ts"],
      "weysabi-server/*": ["packages/server/src/*"]
    }
  },
  "include": ["packages/*/src", "packages/server/drizzle.config.ts"],
  "exclude": ["packages/webapp/src"]
}
